PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Supabase PostgreSQL — pooled connection for app runtime (port 6543, pgbouncer=true)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Supabase PostgreSQL — direct connection for Prisma migrations (port 5432)
# Use the "Direct connection" string from Supabase Dashboard → Settings → Database
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require"

JWT_SECRET="your-jwt-secret-min-8-chars"
JWT_EXPIRES_IN="7d"
ADMIN_EMAIL="admin@email.com"
ADMIN_PASSWORD="secure_admin_password"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="admin@gmail.com"
SMTP_PASSWORD="password"
EMAIL_FROM="Mariah Coirs Export <exports@mariahcoirs.com>"
